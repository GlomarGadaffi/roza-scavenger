/*
 * @Description: Voice-over-FSK Walkie Talkie (Fixed)
 * @Hardware: ESP32-S3 + SX1262 + MSM261 (Mic) + MAX98357A (Amp)
 * @Protocol: FSK @ 19.2 kbps (High Speed/Low Latency)
 * @Codec: Codec2 (Mode 3200) — 8 bytes/frame, 160 samples/frame, 20ms/frame
 *
 * Fixes vs. original:
 *   1. Thread-safe ring buffers replace std::vector (no more race conditions)
 *   2. Correct Codec2 3200 frame size: 8 bytes, not 40
 *   3. Packet payload reduced to 40 bytes (5 frames = 100ms) for low latency
 *   4. Gain with int32_t saturation (no silent wrap)
 *   5. Bounded RX buffer prevents OOM
 *   6. Non-blocking debounce via millis()
 *   7. Self-MAC filtering implemented
 *   8. O(1) ring buffer ops replace O(n) vector::erase-from-front
 */

#include <Arduino.h>
#include "RadioLib.h"
#include "pin_config.h"
#include "Arduino_DriveBus_Library.h"
#include "codec2.h"

// --- Audio Configuration ---
#define IIS_SAMPLE_RATE 8000
#define IIS_DATA_BIT    16

// --- Radio Configuration ---
#define FSK_FREQ        914.6   // MHz (US ISM)
#define FSK_BITRATE     19.2    // kbps
#define FSK_FREQ_DEV    10.0    // kHz
#define FSK_RX_BW       39.0    // kHz
#define FSK_PWR         22      // dBm
#define FSK_PREAMBLE    16      // bits

// --- Packet Sizing ---
// Codec2 3200: 8 bytes/frame, 160 samples (20ms) per frame
// 5 frames × 8 bytes = 40 bytes payload = 100ms of audio per packet
// Total packet: 12 (header) + 40 (payload) = 52 bytes = 416 bits
// At 19.2 kbps → ~22ms air time. Comfortable headroom.
#define PACKET_HEADER_SIZE  12
#define PACKET_PAYLOAD_SIZE 40

// --- Debounce ---
#define DEBOUNCE_MS 200

// --- Audio Gain ---
#define AUDIO_GAIN 5

// =============================================================================
// Thread-Safe Ring Buffer
// =============================================================================
template <typename T, size_t CAPACITY>
class RingBuffer {
public:
    RingBuffer() : _head(0), _tail(0), _count(0) {
        _mutex = xSemaphoreCreateMutex();
    }

    // Push N items. Returns number actually pushed (drops if full).
    size_t push(const T* data, size_t n) {
        xSemaphoreTake(_mutex, portMAX_DELAY);
        size_t pushed = 0;
        for (size_t i = 0; i < n && _count < CAPACITY; i++) {
            _buf[_head] = data[i];
            _head = (_head + 1) % CAPACITY;
            _count++;
            pushed++;
        }
        xSemaphoreGive(_mutex);
        return pushed;
    }

    // Pop N items into dest. Returns number actually popped.
    size_t pop(T* dest, size_t n) {
        xSemaphoreTake(_mutex, portMAX_DELAY);
        size_t popped = 0;
        for (size_t i = 0; i < n && _count > 0; i++) {
            dest[i] = _buf[_tail];
            _tail = (_tail + 1) % CAPACITY;
            _count--;
            popped++;
        }
        xSemaphoreGive(_mutex);
        return popped;
    }

    size_t available() {
        xSemaphoreTake(_mutex, portMAX_DELAY);
        size_t c = _count;
        xSemaphoreGive(_mutex);
        return c;
    }

    size_t free_space() {
        xSemaphoreTake(_mutex, portMAX_DELAY);
        size_t f = CAPACITY - _count;
        xSemaphoreGive(_mutex);
        return f;
    }

    void clear() {
        xSemaphoreTake(_mutex, portMAX_DELAY);
        _head = _tail = _count = 0;
        xSemaphoreGive(_mutex);
    }

private:
    T _buf[CAPACITY];
    size_t _head, _tail, _count;
    SemaphoreHandle_t _mutex;
};

// =============================================================================
// Buffer Instances
// =============================================================================

// Radio TX: codec bytes waiting to be packetized and sent
// ~250 bytes = ~6 packets worth of buffering
static RingBuffer<uint8_t, 256> Radio_Tx_Ring;

// Radio RX: codec bytes received, waiting for decode
// 200 bytes = ~500ms of audio max — prevents OOM, drops oldest implicitly
static RingBuffer<uint8_t, 200> Radio_Rx_Ring;

// Speaker: decoded stereo int16_t samples waiting for playback
// 3200 samples = 200ms stereo at 8kHz (160 samples × 2 channels × ~10 frames)
static RingBuffer<int16_t, 3200> Speaker_Ring;

// =============================================================================
// Globals
// =============================================================================
const uint64_t Local_MAC = ESP.getEfuseMac();
volatile bool Radio_Operation_Flag = false;
volatile bool Boot_Key_Flag = false;
bool Transmission_Mode = false;  // false = RX, true = TX

uint8_t Send_Package[PACKET_HEADER_SIZE + PACKET_PAYLOAD_SIZE];
uint8_t Receive_Package[PACKET_HEADER_SIZE + PACKET_PAYLOAD_SIZE];

unsigned long last_button_ms = 0;

// =============================================================================
// Hardware Objects
// =============================================================================
#if defined T3_S3_MVSRBoard_V1_0
std::shared_ptr<Arduino_IIS_DriveBus> IIS_Bus_In =
    std::make_shared<Arduino_HWIIS>(I2S_NUM_0, MSM261_BCLK, MSM261_WS, MSM261_DATA);
#elif defined T3_S3_MVSRBoard_V1_1
std::shared_ptr<Arduino_IIS_DriveBus> IIS_Bus_In =
    std::make_shared<Arduino_HWIIS>(I2S_NUM_0, -1, MP34DT05TR_LRCLK, MP34DT05TR_DATA);
#else
#error "Please select the correct board definition."
#endif

std::unique_ptr<Arduino_IIS> IIS_Mic(new Arduino_MEMS(IIS_Bus_In));

std::shared_ptr<Arduino_IIS_DriveBus> IIS_Bus_Out =
    std::make_shared<Arduino_HWIIS>(I2S_NUM_1, MAX98357A_BCLK, MAX98357A_LRCLK, MAX98357A_DATA);

std::unique_ptr<Arduino_IIS> IIS_Speaker(new Arduino_Amplifier(IIS_Bus_Out));

SX1262 radio = new Module(LORA_CS, LORA_DIO1, LORA_RST, LORA_BUSY, SPI);

// =============================================================================
// Header: "MAC:" + 8-byte EFuse MAC
// =============================================================================
void prepare_header() {
    Send_Package[0] = 'M';
    Send_Package[1] = 'A';
    Send_Package[2] = 'C';
    Send_Package[3] = ':';
    for (int i = 0; i < 8; i++) {
        Send_Package[4 + i] = (uint8_t)(Local_MAC >> (56 - (i * 8)));
    }
}

// Extract MAC from received packet for self-filtering
uint64_t extract_mac(const uint8_t* pkt) {
    uint64_t mac = 0;
    for (int i = 0; i < 8; i++) {
        mac |= ((uint64_t)pkt[4 + i]) << (56 - (i * 8));
    }
    return mac;
}

// =============================================================================
// ISRs
// =============================================================================
void IRAM_ATTR Radio_Interrupt(void) {
    Radio_Operation_Flag = true;
}

void IRAM_ATTR Button_Interrupt(void) {
    Boot_Key_Flag = true;
}

// =============================================================================
// Task: Codec2 Audio Engine (Core 1)
// =============================================================================
void Codec2_Task(void *parameter) {
    struct CODEC2 *c2 = codec2_create(CODEC2_MODE_3200);
    if (!c2) {
        Serial.println("Codec2 Init Failed!");
        vTaskDelete(NULL);
    }

    codec2_set_lpc_post_filter(c2, 1, 0, 0.8, 0.2);

    const int n_samp  = codec2_samples_per_frame(c2); // 160 samples (20ms)
    const int n_bytes = codec2_bytes_per_frame(c2);    // 8 bytes

    int16_t *sample_buf = (int16_t*)malloc(sizeof(int16_t) * n_samp);
    int16_t *decode_buf = (int16_t*)malloc(sizeof(int16_t) * n_samp);
    uint8_t *code_buf   = (uint8_t*)malloc(n_bytes);

    // Stereo output buffer: 2 channels × n_samp
    int16_t *stereo_buf = (int16_t*)malloc(sizeof(int16_t) * n_samp * 2);

    const int frames_per_packet = PACKET_PAYLOAD_SIZE / n_bytes; // 40/8 = 5

    Serial.printf("Audio Engine: %d samples/frame, %d bytes/frame, %d frames/packet (%dms)\n",
                  n_samp, n_bytes, frames_per_packet, frames_per_packet * 20);

    while (1) {
        // --- TX Path: Mic → Encode → Radio TX Ring ---
        if (Transmission_Mode) {
            for (int f = 0; f < frames_per_packet; f++) {
                if (IIS_Mic->IIS_Read_Data(sample_buf, n_samp * sizeof(int16_t))) {
                    codec2_encode(c2, code_buf, sample_buf);
                    Radio_Tx_Ring.push(code_buf, n_bytes);
                }
            }
        }

        // --- RX Path: Radio RX Ring → Decode → Speaker Ring ---
        while (Radio_Rx_Ring.available() >= (size_t)n_bytes) {
            if (Radio_Rx_Ring.pop(code_buf, n_bytes) == (size_t)n_bytes) {
                codec2_decode(c2, decode_buf, code_buf);

                // Mono → Stereo with saturating gain
                for (int i = 0; i < n_samp; i++) {
                    int32_t amplified = (int32_t)decode_buf[i] * AUDIO_GAIN;
                    // Saturate to int16_t range
                    if (amplified > 32767)  amplified = 32767;
                    if (amplified < -32768) amplified = -32768;
                    int16_t val = (int16_t)amplified;
                    stereo_buf[i * 2]     = val;
                    stereo_buf[i * 2 + 1] = val;
                }

                Speaker_Ring.push(stereo_buf, n_samp * 2);
            }
        }

        vTaskDelay(1);
    }
}

// =============================================================================
// Task: Speaker Playback (Core 1)
// =============================================================================
void MAX_Play_Task(void *parameter) {
    const size_t chunk_samples = 320; // stereo samples per write
    int16_t play_buf[chunk_samples];

    while (1) {
        if (Speaker_Ring.available() >= chunk_samples) {
            Speaker_Ring.pop(play_buf, chunk_samples);
            IIS_Speaker->IIS_Write_Data(play_buf, chunk_samples * sizeof(int16_t));
        } else {
            vTaskDelay(2);
        }
    }
}

// =============================================================================
// Setup
// =============================================================================
void setup() {
    Serial.begin(115200);
    prepare_header();

    // Button (non-blocking debounce handled in loop)
    pinMode(0, INPUT_PULLUP);
    attachInterrupt(BOOT_KEY, Button_Interrupt, FALLING);

    // Amp Enable
    pinMode(MAX98357A_SD_MODE, OUTPUT);
    digitalWrite(MAX98357A_SD_MODE, HIGH);

    // Mic Init
    #if defined T3_S3_MVSRBoard_V1_0
        pinMode(MSM261_EN, OUTPUT);
        digitalWrite(MSM261_EN, HIGH);
        IIS_Mic->begin(i2s_mode_t::I2S_MODE_MASTER,
                       ad_iis_data_mode_t::AD_IIS_DATA_IN,
                       i2s_channel_fmt_t::I2S_CHANNEL_FMT_ONLY_RIGHT,
                       IIS_DATA_BIT, IIS_SAMPLE_RATE);
    #elif defined T3_S3_MVSRBoard_V1_1
        pinMode(MP34DT05TR_EN, OUTPUT);
        digitalWrite(MP34DT05TR_EN, LOW);
        IIS_Mic->begin(i2s_mode_t::I2S_MODE_PDM,
                       ad_iis_data_mode_t::AD_IIS_DATA_IN,
                       i2s_channel_fmt_t::I2S_CHANNEL_FMT_ONLY_RIGHT,
                       IIS_DATA_BIT, IIS_SAMPLE_RATE);
    #endif

    // Speaker Init
    IIS_Speaker->begin(i2s_mode_t::I2S_MODE_MASTER,
                       ad_iis_data_mode_t::AD_IIS_DATA_OUT,
                       i2s_channel_fmt_t::I2S_CHANNEL_FMT_RIGHT_LEFT,
                       IIS_DATA_BIT, IIS_SAMPLE_RATE);

    // --- Radio Init ---
    Serial.print("[SX1262] Initializing FSK ... ");
    SPI.begin(LORA_SCLK, LORA_MISO, LORA_MOSI);

    int state = radio.beginFSK(FSK_FREQ, FSK_BITRATE, FSK_FREQ_DEV,
                                FSK_RX_BW, FSK_PWR, FSK_PREAMBLE, 1.6);

    if (state == RADIOLIB_ERR_NONE) {
        Serial.println("Success!");
    } else {
        Serial.printf("Failed, code %d\n", state);
        while (true);
    }

    uint8_t syncWord[] = {0x2D, 0xD4};
    radio.setSyncWord(syncWord, 2);
    radio.setCRC(2);
    radio.setWhitening(true);
    radio.setPacketMode(RADIOLIB_SX126X_GFSK_PACKET_VARIABLE);
    radio.setDio1Action(Radio_Interrupt);

    // Audio tasks on Core 1, radio on Core 0 (loop)
    xTaskCreatePinnedToCore(Codec2_Task,  "AudioEngine", 32000, NULL, 5, NULL, 1);
    xTaskCreatePinnedToCore(MAX_Play_Task, "Player",     10000, NULL, 5, NULL, 1);

    // Start listening
    radio.startReceive();
    Serial.println("<<< LISTEN MODE >>>");
}

// =============================================================================
// Main Loop (Core 0) — Radio + Button
// =============================================================================
void loop() {

    // --- 1. Non-blocking debounced button ---
    if (Boot_Key_Flag) {
        unsigned long now = millis();
        if (now - last_button_ms >= DEBOUNCE_MS) {
            last_button_ms = now;

            Transmission_Mode = !Transmission_Mode;

            // Flush all buffers on mode switch
            Radio_Tx_Ring.clear();
            Radio_Rx_Ring.clear();
            Speaker_Ring.clear();

            if (Transmission_Mode) {
                Serial.println(">>> TALK MODE <<<");
            } else {
                Serial.println("<<< LISTEN MODE >>>");
                radio.startReceive();
            }
        }
        Boot_Key_Flag = false;
    }

    // --- 2. TX: Ship packets when we have enough encoded data ---
    if (Transmission_Mode && Radio_Tx_Ring.available() >= PACKET_PAYLOAD_SIZE) {

        Radio_Tx_Ring.pop(&Send_Package[PACKET_HEADER_SIZE], PACKET_PAYLOAD_SIZE);

        // Blocking TX is fine — 52 bytes @ 19.2 kbps ≈ 22ms
        radio.transmit(Send_Package, PACKET_HEADER_SIZE + PACKET_PAYLOAD_SIZE);
    }

    // --- 3. RX: Handle radio interrupt ---
    if (Radio_Operation_Flag) {
        Radio_Operation_Flag = false;

        uint16_t flags = radio.getIRQFlags();

        if ((flags & RADIOLIB_SX126X_IRQ_RX_DONE) &&
            !(flags & RADIOLIB_SX126X_IRQ_CRC_ERR)) {

            int state = radio.readData(Receive_Package,
                                       PACKET_HEADER_SIZE + PACKET_PAYLOAD_SIZE);

            if (state == RADIOLIB_ERR_NONE) {
                // Verify header magic
                if (Receive_Package[0] == 'M' &&
                    Receive_Package[1] == 'A' &&
                    Receive_Package[2] == 'C' &&
                    Receive_Package[3] == ':') {

                    // Self-MAC filter: ignore our own transmissions
                    uint64_t sender_mac = extract_mac(Receive_Package);
                    if (sender_mac != Local_MAC) {
                        Radio_Rx_Ring.push(&Receive_Package[PACKET_HEADER_SIZE],
                                          PACKET_PAYLOAD_SIZE);
                        Serial.printf("RX: %d dBm\n", (int)radio.getRSSI());
                    }
                }
            }
        }

        // Resume listening if in RX mode
        if (!Transmission_Mode) {
            radio.startReceive();
        }
    }

    vTaskDelay(2);
}
